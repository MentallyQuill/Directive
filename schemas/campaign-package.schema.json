{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://directive.local/schemas/campaign-package.schema.json",
  "title": "Directive Open-World Campaign Package",
  "description": "Schema v2 root for a data-only Directive open-world campaign package.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest",
    "ship",
    "crew",
    "characterCreation",
    "world",
    "storyArcs",
    "endConditions",
    "questTemplates",
    "threadTemplates",
    "reactionRules",
    "directorCards",
    "contextPolicy",
    "guardrails",
    "assets"
  ],
  "properties": {
    "manifest": { "$ref": "packages/manifest.schema.json" },
    "ship": { "$ref": "packages/ship.schema.json" },
    "crew": { "$ref": "packages/crew.schema.json" },
    "characterCreation": { "$ref": "packages/character-creation.schema.json" },
    "world": { "$ref": "world/world.schema.json" },
    "storyArcs": { "$ref": "story/story-arcs.schema.json" },
    "endConditions": { "$ref": "endings/end-conditions.schema.json" },
    "questTemplates": { "$ref": "quests/quest-templates.schema.json" },
    "threadTemplates": { "$ref": "threads/thread-templates.schema.json" },
    "reactionRules": { "$ref": "reactions/reaction-rules.schema.json" },
    "directorCards": { "$ref": "directors/director-cards.schema.json" },
    "contextPolicy": { "$ref": "generation/context-policy.schema.json" },
    "guardrails": { "$ref": "packages/guardrails.schema.json" },
    "assets": { "$ref": "packages/assets.schema.json" }
  }
}
