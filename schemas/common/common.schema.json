{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://directive.local/schemas/common/common.schema.json",
  "title": "Directive Common Schema Definitions",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]*$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stardate": {
      "type": "number"
    },
    "sourceDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "path"],
      "properties": {
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "path": { "$ref": "#/$defs/nonEmptyString" },
        "version": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "unresolvedList": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    }
  }
}
