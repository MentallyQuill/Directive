{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://directive.local/schemas/campaign/main-campaign.schema.json",
  "title": "Directive Starship Package Main Campaign",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "sourceVersion",
    "openingStardate",
    "openingYear",
    "theater",
    "highConcept",
    "thesis",
    "startingDirectives",
    "stateTracks",
    "campaignAssets",
    "structure",
    "chapters",
    "factions",
    "recurringActors"
  ],
  "properties": {
    "id": { "$ref": "../common/common.schema.json#/$defs/id" },
    "title": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
    "sourceVersion": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
    "openingStardate": { "$ref": "../common/common.schema.json#/$defs/stardate" },
    "openingYear": { "type": "integer" },
    "theater": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
    "highConcept": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
    "thesis": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
    "startingDirectives": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" }
    },
    "stateTracks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stateTrack" }
    },
    "campaignAssets": {
      "type": "array",
      "items": { "$ref": "#/$defs/campaignAsset" }
    },
    "structure": { "type": "object" },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/chapter" }
    },
    "factions": {
      "type": "array",
      "items": { "$ref": "#/$defs/faction" }
    },
    "recurringActors": {
      "type": "array",
      "items": { "$ref": "#/$defs/actor" }
    }
  },
  "$defs": {
    "stateTrack": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "label", "visibility", "initial"],
      "properties": {
        "id": { "$ref": "../common/common.schema.json#/$defs/id" },
        "label": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "visibility": { "enum": ["hidden", "playerFacing", "debugOnly"] },
        "initial": { "type": ["integer", "number", "string", "null"] },
        "min": { "type": ["integer", "number"] },
        "max": { "type": ["integer", "number"] }
      }
    },
    "campaignAsset": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "label", "defaultState"],
      "properties": {
        "id": { "$ref": "../common/common.schema.json#/$defs/id" },
        "label": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "defaultState": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" }
      }
    },
    "chapter": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type", "title", "question", "pressure"],
      "properties": {
        "id": { "$ref": "../common/common.schema.json#/$defs/id" },
        "type": {
          "type": "string",
          "enum": ["prelude", "main", "openOrders", "finale", "epilogue"]
        },
        "title": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "question": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "pressure": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "stardateRange": { "type": "string" }
      }
    },
    "faction": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "label", "role"],
      "properties": {
        "id": { "$ref": "../common/common.schema.json#/$defs/id" },
        "label": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "role": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "name", "role"],
      "properties": {
        "id": { "$ref": "../common/common.schema.json#/$defs/id" },
        "name": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "role": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "affiliation": { "type": "string" }
      }
    }
  }
}
