{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive.runtime.lensPromptBudgetTrace.v1",
  "title": "Directive LENS Prompt Budget Trace",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "packetId", "promptRevision", "cacheKey", "lanes", "cacheInputs", "hash", "byteLength"],
  "properties": {
    "kind": { "const": "directive.lensPromptBudgetTrace.v1" },
    "schemaVersion": { "const": 1 },
    "packetId": { "type": ["string", "null"] },
    "promptRevision": { "type": ["number", "null"] },
    "cacheKey": { "type": ["string", "null"] },
    "lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "budgetTokens", "estimatedTokens", "reservedFloor", "reservedFloorSatisfied", "includedRefs", "omittedRefs", "overBudgetRefs", "omissionReasons", "authority", "diagnosticOnly", "overflowPolicy", "budgetExceeded", "blocking", "status"],
        "properties": {
          "id": {
            "enum": [
              "stableRules",
              "protectedContinuity",
              "activeScene",
              "activeCast",
              "missionPressure",
              "recentTranscript",
              "recall",
              "volatileTurn",
              "externalEnvironment"
            ]
          },
          "budgetTokens": { "type": "integer", "minimum": 0 },
          "estimatedTokens": { "type": "integer", "minimum": 0 },
          "reservedFloor": { "type": "integer", "minimum": 0 },
          "reservedFloorSatisfied": { "type": "boolean" },
          "includedRefs": { "type": "array" },
          "omittedRefs": { "type": "array" },
          "overBudgetRefs": { "type": "array" },
          "omissionReasons": { "type": "array", "items": { "type": "string" } },
          "authority": { "type": "string" },
          "diagnosticOnly": { "type": "boolean" },
          "overflowPolicy": {
            "enum": ["omit-overflow", "fail-closed", "diagnostic-only"]
          },
          "budgetExceeded": { "type": "boolean" },
          "blocking": { "type": "boolean" },
          "status": {
            "enum": ["within-budget", "omitted-overflow", "blocked-over-budget", "diagnostic-only"]
          }
        }
      }
    },
    "cacheInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mechanicsRevision", "promptDomainVector", "recallIndexRevision", "sceneSealRevision", "pressureArcDigestRevision", "packageRevision", "externalPromptEnvironmentRef", "externalPromptEnvironmentTargets"],
      "properties": {
        "mechanicsRevision": { "type": ["number", "null"] },
        "promptDomainVector": { "type": ["object", "null"] },
        "recallIndexRevision": { "type": ["string", "null"] },
        "sceneSealRevision": { "type": ["string", "null"] },
        "pressureArcDigestRevision": { "type": ["string", "null"] },
        "packageRevision": { "type": ["string", "null"] },
        "promptBudgetLaneOverrides": { "type": ["object", "null"] },
        "externalPromptEnvironmentRef": { "type": ["object", "null"] },
        "externalPromptEnvironmentTargets": { "type": ["object", "null"] }
      }
    },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "byteLength": { "type": "integer", "minimum": 0 }
  }
}
