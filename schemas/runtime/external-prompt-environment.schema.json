{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive.runtime.externalPromptEnvironment.v1",
  "title": "Directive External Prompt Environment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "host",
    "worldInfo",
    "memoryBooks",
    "summaryception",
    "vectFox",
    "unknownExternalContext",
    "diagnostics",
    "knownExternalPromptKeys",
    "redactions",
    "hash",
    "byteLength"
  ],
  "properties": {
    "kind": { "const": "directive.externalPromptEnvironment.v1" },
    "schemaVersion": { "const": 1 },
    "host": { "type": "string", "minLength": 1 },
    "userHandle": { "type": ["string", "null"] },
    "chatId": { "type": ["string", "null"] },
    "saveId": { "type": ["string", "null"] },
    "campaignId": { "type": ["string", "null"] },
    "observedAt": { "type": ["string", "null"] },
    "status": { "enum": ["observed", "unknown", "unavailable", "error"] },
    "worldInfo": { "$ref": "#/$defs/worldInfo" },
    "memoryBooks": { "$ref": "#/$defs/memoryBooks" },
    "summaryception": { "$ref": "#/$defs/summaryception" },
    "vectFox": { "$ref": "#/$defs/vectFox" },
    "unknownExternalContext": { "$ref": "#/$defs/unknownExternalContext" },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    },
    "knownExternalPromptKeys": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "unknownSignals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "redactions": {
      "type": "array",
      "items": { "$ref": "#/$defs/redaction" }
    },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "byteLength": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "worldInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "installed": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "active": { "type": "boolean" },
        "activeNames": { "type": "array", "items": { "type": "string" } },
        "chatBoundName": { "type": ["string", "null"] },
        "settingsHash": { "type": ["string", "null"] },
        "depth": { "type": ["number", "null"] },
        "budgetPercent": { "type": ["number", "null"] },
        "recursive": { "type": "boolean" },
        "promptPositions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "memoryBooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "installed": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "activeBookName": { "type": ["string", "null"] },
        "stMemoryBookEntryCount": { "type": "integer", "minimum": 0 },
        "stMemoryBookEntryHash": { "type": ["string", "null"] },
        "rangeDiagnostics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string" },
            "entryRangeCount": { "type": "integer", "minimum": 0 },
            "chatRangeCount": { "type": "integer", "minimum": 0 },
            "validRangeCount": { "type": "integer", "minimum": 0 },
            "invertedRangeCount": { "type": "integer", "minimum": 0 },
            "outOfBoundsRangeCount": { "type": "integer", "minimum": 0 },
            "staleRangeCount": { "type": "integer", "minimum": 0 },
            "rangeHash": { "type": ["string", "null"] }
          }
        },
        "riskyModes": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "autoSummary": { "type": "boolean" },
            "autoCreate": { "type": "boolean" },
            "autoHideUnhide": { "type": "boolean" },
            "sidePrompts": { "type": "boolean" },
            "atDepthUserOrAssistant": { "type": "boolean" }
          }
        }
      }
    },
    "summaryception": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "installed": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "promptKey": { "type": "string" },
        "promptKeyActive": { "type": "boolean" },
        "summarizedUpTo": { "type": "number" },
        "layerCount": { "type": "integer", "minimum": 0 },
        "ghostedCount": { "type": "integer", "minimum": 0 },
        "staleness": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string" },
            "chatLength": { "type": "integer", "minimum": 0 },
            "summarizedRangeBeyondChat": { "type": "boolean" },
            "staleAfterMutation": { "type": "boolean" },
            "ghostedSystemVisibleCount": { "type": "integer", "minimum": 0 },
            "summarizedOnlyCount": { "type": "integer", "minimum": 0 }
          }
        },
        "injectionHash": { "type": ["string", "null"] },
        "externalModelCalls": { "type": "boolean" }
      }
    },
    "vectFox": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "installed": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "disabledPresent": { "type": "boolean" },
        "promptKeys": { "type": "array", "items": { "type": "string" } },
        "position": { "type": ["number", "null"] },
        "depth": { "type": ["number", "null"] },
        "backendType": { "type": ["string", "null"] },
        "semanticWorldInfoEnabled": { "type": "boolean" },
        "summarizerInjectionEnabled": { "type": "boolean" },
        "ghostingEnabled": { "type": "boolean" },
        "generationInterceptorActive": { "type": "boolean" },
        "backendDiagnostics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string" },
            "backendType": { "type": ["string", "null"] },
            "unavailable": { "type": "boolean" },
            "externalTimingObserved": { "type": "boolean" },
            "interceptorLatencyMs": { "type": ["number", "null"] },
            "retrievalLatencyMs": { "type": ["number", "null"] },
            "timingHash": { "type": ["string", "null"] }
          }
        },
        "settingsHash": { "type": ["string", "null"] }
      }
    },
    "unknownExternalContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string" },
        "promptKeyCount": { "type": "integer", "minimum": 0 },
        "promptKeyPrefixes": { "type": "array", "items": { "type": "string" } },
        "promptKeyHash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "promptKeyPrefixHash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "visibilityMarkerCount": { "type": "integer", "minimum": 0 },
        "redactionReason": { "type": ["string", "null"] }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "schemaVersion",
        "layer",
        "target",
        "status",
        "source",
        "mergeSource",
        "evidenceHash",
        "authority",
        "rawContentCaptured"
      ],
      "properties": {
        "kind": { "const": "directive.externalPromptEnvironmentDiagnostic.v1" },
        "schemaVersion": { "const": 1 },
        "layer": {
          "enum": [
            "directiveOwnedPromptPacket",
            "hostFinalPromptComposition",
            "modelVisibleGenerationEnvironment"
          ]
        },
        "target": {
          "enum": [
            "stLorebooks",
            "memoryBooks",
            "summaryception",
            "vectFox",
            "unknownExternalContext"
          ]
        },
        "status": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "mergeSource": { "type": "string", "minLength": 1 },
        "evidenceHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "authority": {
          "type": "object",
          "additionalProperties": false,
          "required": ["directiveAuthority", "role"],
          "properties": {
            "directiveAuthority": { "const": false },
            "role": { "const": "diagnostics-provenance-only" }
          }
        },
        "rawContentCaptured": { "const": false }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "reason"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "reason": { "enum": ["secret", "raw-payload"] }
      }
    }
  }
}
