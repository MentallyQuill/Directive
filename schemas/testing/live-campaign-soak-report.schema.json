{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://directive.local/schemas/testing/live-campaign-soak-report.schema.json",
  "title": "Directive Live Campaign Soak Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "runId",
    "generatedAt",
    "mode",
    "status",
    "modelCallPolicy",
    "driverPolicy",
    "artifacts",
    "liveLogPolicy",
    "readableTranscriptPolicy",
    "playerInputPolicy",
    "checks",
    "campaignMatrix",
    "phases",
    "turnScript",
    "endConditionScenarios"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "const": "directive.liveCampaignSoak.report"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "enum": ["dry-run", "preflight", "live", "fallback-only"]
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "warning", "skipped", "not-run"]
    },
    "baseUrl": {
      "type": ["string", "null"]
    },
    "extensionPath": {
      "type": "string"
    },
    "modelCallPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["budget", "liveProvidersRequired", "fallbackWarningRequired"],
      "properties": {
        "budget": {
          "type": "string",
          "const": "unlimited"
        },
        "liveProvidersRequired": {
          "type": "boolean",
          "const": true
        },
        "fallbackWarningRequired": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "driverPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "fallbacks", "fallbackEvidenceIsEquivalent"],
      "properties": {
        "primary": {
          "type": "string",
          "const": "playwright"
        },
        "fallbacks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallbackEvidenceIsEquivalent": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "required": [
        "root",
        "report",
        "summary",
        "liveLog",
        "turns",
        "transcript",
        "readableTranscript",
        "sourceChatTranscript",
        "transcriptIndex"
      ]
    },
    "liveLogPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact",
        "appendOnly",
        "flushAfterEveryRecord",
        "partialRunProofRequired",
        "updateCadence",
        "recordKinds"
      ],
      "properties": {
        "artifact": {
          "type": "string",
          "const": "live-log.jsonl"
        },
        "appendOnly": {
          "type": "boolean",
          "const": true
        },
        "flushAfterEveryRecord": {
          "type": "boolean",
          "const": true
        },
        "partialRunProofRequired": {
          "type": "boolean",
          "const": true
        },
        "updateCadence": {
          "type": "string",
          "minLength": 1
        },
        "recordKinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "readableTranscriptPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "artifactDirectory",
        "readableArtifact",
        "sourceArtifact",
        "indexArtifact",
        "excerptsArtifact",
        "scope",
        "captureCadence",
        "hiddenStatePolicy"
      ],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true
        },
        "artifactDirectory": {
          "type": "string",
          "const": "transcript"
        },
        "readableArtifact": {
          "type": "string",
          "minLength": 1
        },
        "sourceArtifact": {
          "type": "string",
          "minLength": 1
        },
        "indexArtifact": {
          "type": "string",
          "minLength": 1
        },
        "excerptsArtifact": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "captureCadence": {
          "type": "string",
          "minLength": 1
        },
        "hiddenStatePolicy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "playerInputPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "style",
        "pointOfView",
        "agencyBoundary",
        "adversarialStyle",
        "maximumVisibleMetaTesting",
        "qualityDimensions"
      ],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true
        },
        "style": {
          "type": "string",
          "minLength": 1
        },
        "pointOfView": {
          "type": "string",
          "minLength": 1
        },
        "agencyBoundary": {
          "type": "string",
          "minLength": 1
        },
        "adversarialStyle": {
          "type": "string",
          "minLength": 1
        },
        "maximumVisibleMetaTesting": {
          "type": "string",
          "minLength": 1
        },
        "qualityDimensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "campaignMatrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/campaignMatrixEntry"
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/phase"
      }
    },
    "turnScript": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/turnIntent"
      }
    },
    "endConditionScenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/endConditionScenario"
      }
    },
    "servedExtension": {
      "type": ["object", "null"]
    },
    "environment": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "summary"],
      "properties": {
        "id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "warning", "skipped", "not-run"]
        },
        "summary": {
          "type": "string"
        },
        "details": {
          "type": ["object", "array", "string", "number", "boolean", "null"]
        }
      }
    },
    "campaignMatrixEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageId",
        "title",
        "packagePath",
        "theater",
        "status",
        "deterministicCoverage",
        "liveCoverage",
        "requiredCanaryTurns",
        "requiredLiveChecks",
        "focus"
      ],
      "properties": {
        "packageId": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "packagePath": {
          "type": "string",
          "minLength": 1
        },
        "theater": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "deterministicCoverage": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "liveCoverage": {
          "type": "string",
          "enum": ["full-soak-rotation-primary", "short-live-canary"]
        },
        "requiredCanaryTurns": {
          "type": "integer",
          "minimum": 1
        },
        "requiredLiveChecks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "focus": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "turnRange", "purpose", "status"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "turnRange": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["planned", "running", "pass", "fail", "warning", "skipped", "not-run"]
        }
      }
    },
    "turnIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["turn", "intent"],
      "properties": {
        "turn": {
          "type": "integer",
          "minimum": 1
        },
        "intent": {
          "type": "string"
        },
        "category": {
          "type": "string"
        }
      }
    },
    "endConditionScenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "intent", "expectedInteractionKind", "expectedAction", "expectedDecisionStatus"],
      "properties": {
        "id": {
          "type": "string"
        },
        "intent": {
          "type": "string"
        },
        "expectedInteractionKind": {
          "type": "string",
          "const": "terminalOutcomeDecision"
        },
        "expectedAction": {
          "type": "string",
          "enum": ["saveTerminalBranch", "replayFromCheckpoint", "pushOn", "keepEnding"]
        },
        "expectedDecisionStatus": {
          "type": "string",
          "enum": ["pending", "replayed", "pushedOn", "keptEnding"]
        }
      }
    }
  }
}
