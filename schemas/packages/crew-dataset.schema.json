{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://directive.local/schemas/packages/crew-dataset.schema.json",
  "title": "Directive Crew Dataset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest",
    "sources",
    "officers",
    "relationshipDimensions",
    "developmentDimensions",
    "cards",
    "indexes"
  ],
  "properties": {
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "schemaVersion", "id", "packageId", "title", "version", "status"],
      "properties": {
        "kind": { "const": "directive.crewDataset" },
        "schemaVersion": { "const": 1 },
        "id": { "$ref": "../common/common.schema.json#/$defs/id" },
        "packageId": { "$ref": "../common/common.schema.json#/$defs/id" },
        "title": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "version": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "status": {
          "type": "string",
          "enum": ["draft", "pre-alpha", "playtest", "stable"]
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "../common/common.schema.json#/$defs/sourceDocument" }
    },
    "officers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/officerContract" }
    },
    "relationshipDimensions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dimensionContract" }
    },
    "developmentDimensions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dimensionContract" }
    },
    "cards": {
      "type": "array",
      "items": { "$ref": "director-card.schema.json" }
    },
    "indexes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["byOfficer", "byType", "byAudience", "byRevealGate"],
      "properties": {
        "byOfficer": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "../common/common.schema.json#/$defs/id" }
          }
        },
        "byType": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "../common/common.schema.json#/$defs/id" }
          }
        },
        "byAudience": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "../common/common.schema.json#/$defs/id" }
          }
        },
        "byRevealGate": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "../common/common.schema.json#/$defs/id" }
          }
        }
      }
    }
  },
  "$defs": {
    "officerContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "billet", "ageDescription", "requiredCardTypes"],
      "properties": {
        "id": { "$ref": "../common/common.schema.json#/$defs/id" },
        "name": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "billet": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "ageDescription": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "requiredCardTypes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/crewCardType" }
        }
      }
    },
    "dimensionContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "visibility"],
      "properties": {
        "id": { "$ref": "../common/common.schema.json#/$defs/id" },
        "label": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "visibility": {
          "type": "string",
          "enum": ["hidden", "playerFacing", "debugOnly"]
        },
        "summary": { "type": "string" }
      }
    },
    "crewCardType": {
      "type": "string",
      "enum": [
        "crew.profile",
        "crew.voice",
        "crew.relationship",
        "crew.reveal",
        "crew.bplot",
        "crew.coalitionRule",
        "crew.development",
        "command.styleReaction"
      ]
    }
  }
}
