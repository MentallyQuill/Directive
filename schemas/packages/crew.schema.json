{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://directive.local/schemas/packages/crew.schema.json",
  "title": "Directive Campaign Package Crew",
  "type": "object",
  "additionalProperties": true,
  "required": ["senior", "cohorts", "relationshipModel"],
  "properties": {
    "senior": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/crewMember" }
    },
    "cohorts": {
      "type": "array",
      "items": { "$ref": "#/$defs/cohort" }
    },
    "relationshipModel": {
      "type": "object",
      "required": ["dimensions", "rawValuesHidden"],
      "properties": {
        "dimensions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" }
        },
        "rawValuesHidden": { "const": true }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "crewMember": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "name", "rank", "billet", "species", "status"],
      "properties": {
        "id": { "$ref": "../common/common.schema.json#/$defs/id" },
        "name": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "rank": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "billet": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "species": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "status": {
          "type": "string",
          "enum": ["locked", "draft", "placeholder"]
        }
      }
    },
    "cohort": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "label", "summary"],
      "properties": {
        "id": { "$ref": "../common/common.schema.json#/$defs/id" },
        "label": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" },
        "summary": { "$ref": "../common/common.schema.json#/$defs/nonEmptyString" }
      }
    }
  }
}
