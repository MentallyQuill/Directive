{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://directive.local/schemas/generation/continuity-claim-extraction.schema.json",
  "title": "Directive Continuity Claim Extraction",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "claims"],
  "properties": {
    "kind": { "const": "directive.continuityClaimExtraction.v1" },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "categories", "confidence"],
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "categories": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
